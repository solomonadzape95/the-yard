# Copy to .env in this folder (never commit .env)

# Required for --network og — must be a JSON-RPC endpoint (POST), not the block explorer.
# Galileo testnet examples (chain ID 16602): https://evmrpc-testnet.0g.ai
# Explorer https://chainscan-galileo.0g.ai returns HTML/405 and will NOT work here.
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Deployer private key: exactly 64 hex characters (optionally prefixed with 0x).
# No quotes unless your tool requires them. This wallet needs gas on the OG_RPC_URL chain.
PRIVATE_KEY=
